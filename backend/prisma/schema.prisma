// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String

  /// New signups set to false until OTP is verified; @default(true) keeps existing rows verified after migration.
  emailVerified     Boolean   @default(true)
  emailOtpHash      String?
  emailOtpExpiresAt DateTime?

  createdAt DateTime @default(now())

  authEvents AuthEvent[]
}

model PendingRegistration {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  emailOtpHash String
  emailOtpExpiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("RegistrationPending")
}

model AuthEvent {
  id        String          @id @default(uuid())
  userId    String?
  eventType AuthEventType
  status    AuthEventStatus
  ipAddress String?
  metadata  Json?
  createdAt DateTime        @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([eventType, status, createdAt])
  @@index([userId, createdAt])
}

enum AuthEventType {
  LOGIN
  OTP_EMAIL_VERIFICATION
  OTP_PASSWORD_RESET
}

enum AuthEventStatus {
  SUCCESS
  FAILURE
}
