# Prisma 7 + CLI need Node >= 20.19. Node 18 → ERR_REQUIRE_ESM (zeptomatch).
# Conda: create env with Node 22 →  conda env create -f environment.yml
#   then: conda activate tanstack-backend && npm install
# Or: conda install -c conda-forge nodejs=22
# Debug which Node npm uses:  npm run node:path
# Full check: npm run doctor
# If `node` is v18 from /usr/local (brew) but you use nvm:
#   npm run doctor:nvm
#   npm run db:studio:nvm
# If nvm says npm_config_prefix: scripts unset it; or run: unset npm_config_prefix
# nvm: cd backend && nvm install && nvm use   (.nvmrc = Node 22; first time needs install)

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Prisma Studio — if you see "Unable to communicate with Prisma Client":
# 1) Stop Studio (Ctrl+C), run from this folder: npm run db:studio
# 2) Open http://localhost:5555 in a normal browser (not a broken embedded preview)
# 3) Hard refresh (Shift+Reload) or clear site data for localhost:5555
# 4) Try another port: npm run db:studio:5556
# 5) Run: npx prisma generate   then restart Studio
# 6) Ensure DATABASE_URL works (wake Neon, VPN/firewall off port 5432)

# Optional: tune node-pg pool (helps Neon cold start / timeouts)
# PG_POOL_MAX=10
# PG_CONNECTION_TIMEOUT_MS=25000
# PG_IDLE_TIMEOUT_MS=60000
NODE_ENV=development
PORT=5001

# SPA origin for CORS + cookies when the frontend is not proxied (e.g. production)
FRONTEND_URL="http://localhost:5173"

# Access JWT: short-lived, send as Authorization: Bearer <token> on API calls
JWT_ACCESS_SECRET="replace_with_a_long_random_access_secret"
ACCESS_TOKEN_EXPIRES_IN="15m"

# Refresh JWT: httpOnly cookie only (not for API Authorization)
JWT_REFRESH_SECRET="replace_with_a_different_long_random_refresh_secret"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Legacy: if JWT_ACCESS_SECRET / JWT_REFRESH_SECRET are unset, JWT_SECRET is used for both (dev only)
# JWT_SECRET="replace_with_a_long_random_secret"
