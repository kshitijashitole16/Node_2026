# Copy to .env and fill in values.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# JWT (match your deployment)
# JWT_ACCESS_SECRET=
# JWT_SECRET=

# Admin-only analytics lists (GET /analytics/auth/events, /users)
# FAST_AUTH_ADMIN_SECRET=
# FAST_AUTH_ADMIN_EMAILS=you@example.com,admin@example.com

