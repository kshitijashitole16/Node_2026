{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/**",
          "backend/node_modules/.prisma/client/**",
          "backend/node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/movies/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/watchlist/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}
